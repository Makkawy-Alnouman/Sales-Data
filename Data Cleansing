monthly_data = df_2015_2017.groupby(df_2015_2017['Order Date'].dt.to_period('M')).agg({
    'Sales': 'sum',
    'Discount': 'sum',
    'Profit': 'sum'
})

# Calculate the monthly averages for each metric
